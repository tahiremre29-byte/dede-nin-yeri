# DD1 Platform — Environment Variables
# Bu dosyayı .env olarak kopyala ve değerleri doldur:
#   cp .env.example .env

# ── Zorunlu ───────────────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSy...buraya_gercek_key_yaz

# ── Opsiyonel ─────────────────────────────────────────────────────────────────
DD1_ENV=development          # development | test | production
AI_BACKEND_MODE=developer    # developer | vertex
GEMINI_MODEL_NAME=gemini-2.0-flash
AI_TIMEOUT_SECONDS=30
AI_RETRY_COUNT=3
STREAM_ENABLED=false

# ── Vertex AI (AI_BACKEND_MODE=vertex ise doldur) ─────────────────────────────
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
